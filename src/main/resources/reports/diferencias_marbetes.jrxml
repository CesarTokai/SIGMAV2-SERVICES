            <staticText>
                <reportElement style="Table_CH" x="295" y="0" width="45"  height="20" uuid="11111111-1111-1111-1111-111111111105"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="7" isBold="true"/>
                </textElement>
                <text><![CDATA[Clv Alm]]></text>
            </staticText>
            <staticText>
                <reportElement style="Table_CH" x="340" y="0" width="70" height="20" uuid="11111111-1111-1111-1111-111111111107"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Conteo 1]]></text>
            </staticText>
            <staticText>
                <reportElement style="Table_CH" x="410" y="0" width="70"  height="20" uuid="11111111-1111-1111-1111-111111111108"/>
