                </textElement>
                <text><![CDATA[Diferencia]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ═══════════════ DETALLE ═══════════════ -->
    <detail>
        <band height="18" splitType="Stretch">
            <textField textAdjust="StretchHeight">
                <reportElement style="Table_TD" x="0"   y="0" width="50"  height="18" uuid="22222222-2222-2222-2222-222222222201"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{numeroMarbete}]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight">
                <reportElement style="Table_TD" x="50"  y="0" width="65"  height="18" uuid="22222222-2222-2222-2222-222222222202"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{claveProducto}]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight">
                <reportElement style="Table_TD" x="115" y="0" width="150" height="18" uuid="22222222-2222-2222-2222-222222222203"/>
                <textElement verticalAlignment="Middle"><font fontName="Arial" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{descripcionProducto}]]></textFieldExpression>
            </textField>
            <textField textAdjust="StretchHeight">
                <reportElement style="Table_TD" x="265" y="0" width="30"  height="18" uuid="22222222-2222-2222-2222-222222222204"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Arial" size="8"/></textElement>
                <textFieldExpression><![CDATA[$F{unidad}]]></textFieldExpression>
            </textField>
