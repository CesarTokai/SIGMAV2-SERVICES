                <textElement textAlignment="Center" verticalAlignment="Middle"><font fontName="Arial" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{claveAlmacen}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement style="Table_TD" x="340" y="0" width="70"  height="18" uuid="22222222-2222-2222-2222-222222222207"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{conteo1} == null ? "-" : new java.text.DecimalFormat("#,##0").format($F{conteo1})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement style="Table_TD" x="410" y="0" width="70"  height="18" uuid="22222222-2222-2222-2222-222222222208"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="7"/></textElement>
                <textFieldExpression><![CDATA[$F{conteo2} == null ? "-" : new java.text.DecimalFormat("#,##0").format($F{conteo2})]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement style="Table_TD" x="480" y="0" width="75"  height="18" uuid="22222222-2222-2222-2222-222222222209"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="Arial" size="7" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[new java.text.DecimalFormat("#,##0").format($F{diferencia})]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- ═══════════════ PIE DE PÁGINA ═══════════════ -->
    <pageFooter>
