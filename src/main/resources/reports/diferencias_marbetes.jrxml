<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="listado_marbetes_diferencias"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20"
              whenNoDataType="NoPages"
              uuid="15ef138b-b12c-43b2-84ea-68c7e1fed7c6">

    <!-- ═══════════════ ESTILOS ═══════════════ -->
    <style name="Table_CH" mode="Opaque" backcolor="#BFE1FF"/>
    <style name="Table_TD" mode="Opaque" backcolor="#FFFFFF"/>

    <!-- ═══════════════ PARÁMETROS ═══════════════ -->
    <parameter name="periodId" class="java.lang.Integer"/>
    <parameter name="warehouseId" class="java.lang.Integer"/>
    <parameter name="fecha" class="java.lang.String">
        <defaultValueExpression><![CDATA["Sin fecha"]]></defaultValueExpression>
