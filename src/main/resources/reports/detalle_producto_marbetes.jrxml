    <!-- RESUMEN -->
    <summary>
        <band height="30" splitType="Stretch">
            <line>
                <reportElement x="0" y="0" width="802" height="1" uuid="b2c3d4e5-f6a7-8901-bcde-f12345678950"/>
            </line>
            <staticText>
                <reportElement x="400" y="5" width="170" height="12" uuid="b2c3d4e5-f6a7-8901-bcde-f12345678951"/>
