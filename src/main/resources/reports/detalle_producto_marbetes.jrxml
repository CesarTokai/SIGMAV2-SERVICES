            <staticText>
                <reportElement x="400" y="17" width="170" height="12" uuid="b2c3d4e5-f6a7-8901-bcde-f12345678953"/>
                <textElement textAlignment="Right">
                    <font fontName="Arial" size="8" isBold="true"/>
                </textElement>
                <text><![CDATA[Total cancelados:]]></text>
